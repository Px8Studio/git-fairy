{
  "root": true,
  "env": { "es2022": true, "node": true, "mocha": true },
  "extends": ["eslint:recommended"],
  "parserOptions": { "ecmaVersion": 2022 },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "prefer-const": "warn"
  },
  "ignorePatterns": ["index.d.ts", "dist/**"]
}
